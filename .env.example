DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*

# Desarrollo local (docker-compose levanta un Postgres propio con estas credenciales).
DB_NAME=crm
DB_USER=crm
DB_PASSWORD=crm
DB_HOST=db
DB_PORT=5432

# En producción (Render), en vez de las variables DB_* de arriba, define DATABASE_URL
# con la connection string de Supabase, algo como:
# DATABASE_URL=postgres://postgres:<password>@<host>.supabase.co:5432/postgres
# DB_SSL_REQUIRE=True

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

VITE_API_URL=http://localhost:8000/api
